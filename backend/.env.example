# Environment variables for localhost development

# App configuration
NODE_ENV=development
PORT=3000

# Database
# PostgreSQL connection string for Supabase
# Local Supabase: postgresql://postgres:postgres@127.0.0.1:54322/postgres?sslmode=disable
# Remote Supabase: Get from Supabase Dashboard → Settings → Database
DATABASE_URL=postgresql://postgres:password@127.0.0.1:54322/postgres?sslmode=disable
DATABASE_MIGRATIONS_DIR=./migrations

# OpenAI API Key
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Resend - for contact form email delivery
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# Portfolio cache TTL in ms (default 10 min)
# PORTFOLIO_CACHE_TTL_MS=600000

# Portfolio data: Postgres (Drizzle) or MCP
# PORTFOLIO_DATA_SOURCE=db
#
# When PORTFOLIO_DATA_SOURCE=mcp, set a streamable HTTP URL or a stdio command (one is required):
# MCP_PORTFOLIO_URL=http://127.0.0.1:3333/mcp
# MCP_PORTFOLIO_COMMAND=npx
# MCP_PORTFOLIO_ARGS_JSON=["-y","@your-scope/portfolio-mcp"]
# Optional HTTP auth / headers:
# MCP_PORTFOLIO_BEARER_TOKEN=
# MCP_PORTFOLIO_HEADERS_JSON={"X-Custom":"value"}
#
# Tool names (must match your MCP server):
# MCP_PORTFOLIO_TOOL_GET=get_portfolio
# MCP_RESUME_TOOL_GET=get_resume_pdf
#
# When PORTFOLIO_DATA_SOURCE=mcp, attach the same MCP to chat/job-match/fitcheck agents (default true):
# AGENT_MCP_ENABLED=true
